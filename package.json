{
  "name": "search-code-mcp",
  "version": "1.5.0",
  "description": "MCP server for Claude Code that searches local codebases efficiently, saving tokens by offloading file traversal",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "search-code-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/index.cjs",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run bundle"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "fast-glob": "^3.3.0",
    "ignore": "^7.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
